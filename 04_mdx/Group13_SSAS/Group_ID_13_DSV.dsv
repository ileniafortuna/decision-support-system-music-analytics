            <xs:element name="PseudoFact_WeightedStreams" msprop:QueryBuilder="SpecificQueryBuilder" msprop:IsLogical="True" msprop:design-time-name="bba1b3b1-359a-4e0b-8865-72ade0c5da2a" msprop:QueryDefinition="SELECT f.fact_pk, f.date_song_fk, f.track_fk, f.category_fk, b.artist_fk, f.streams_1month, CASE WHEN b.role = 1 THEN f.streams_1month * 0.8 ELSE f.streams_1month * 0.2 END AS weighted_streams&#xD;&#xA;FROM     FactSongStreams AS f INNER JOIN&#xD;&#xA;                  BridgeFeatured AS b ON f.track_fk = b.track_fk" msprop:FriendlyName="PseudoFact_WeightedStreams" msprop:TableType="View" msprop:DbTableName="PseudoFact_WeightedStreams" msprop:Description="">
              <xs:complexType>
