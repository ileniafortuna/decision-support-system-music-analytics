                  <xs:element name="fact_pk" msdata:ReadOnly="true" msprop:FriendlyName="fact_pk" msprop:DbColumnName="fact_pk" msprop:design-time-name="2ba46f65-23c3-41b4-b405-bf11a46c3717" type="xs:int" minOccurs="0" />
