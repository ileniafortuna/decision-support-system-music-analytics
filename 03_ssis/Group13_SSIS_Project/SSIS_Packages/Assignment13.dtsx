                      name="portfolio_risk"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Espressione colonna derivata"
                          name="Expression">#{Package\DF_Assignment13\artist_profile.Outputs[Output colonna derivata].Columns[artist_profile]} == "Hit-Driven" &amp;&amp; #{Package\DF_Assignment13\Aggregazione.Outputs[Output aggregazione 1].Columns[avg_popularity]} &lt; 40 ? "Viral Risk" : #{Package\DF_Assignment13\artist_profile.Outputs[Output colonna derivata].Columns[artist_profile]} == "Hit-Driven" &amp;&amp; #{Package\DF_Assignment13\Aggregazione.Outputs[Output aggregazione 1].Columns[avg_popularity]} &gt;= 40 ? "Superstar Potential" : #{Package\DF_Assignment13\artist_profile.Outputs[Output colonna derivata].Columns[artist_profile]} == "Catalog-Driven" &amp;&amp; #{Package\DF_Assignment13\Aggregazione.Outputs[Output aggregazione 1].Columns[avg_popularity]} &gt;= 70 ? "Evergreen Asset" : #{Package\DF_Assignment13\artist_profile.Outputs[Output colonna derivata].Columns[artist_profile]} == "Catalog-Driven" &amp;&amp; #{Package\DF_Assignment13\Aggregazione.Outputs[Output aggregazione 1].Columns[avg_popularity]} &lt; 40 ? "Weak Catalog" : #{Package\DF_Assignment13\artist_profile.Outputs[Output colonna derivata].Columns[artist_profile]} == "Mixed" &amp;&amp; #{Package\DF_Assignment13\Aggregazione.Outputs[Output aggregazione 1].Columns[avg_popularity]} &gt;= 50 ? "Growth Candidate" : "Standard Portfolio"</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Espressione descrittiva colonna derivata"
                          expressionType="Notify"
                          name="FriendlyExpression">artist_profile == "Hit-Driven" &amp;&amp; avg_popularity &lt; 40 ? "Viral Risk" : artist_profile == "Hit-Driven" &amp;&amp; avg_popularity &gt;= 40 ? "Superstar Potential" : artist_profile == "Catalog-Driven" &amp;&amp; avg_popularity &gt;= 70 ? "Evergreen Asset" : artist_profile == "Catalog-Driven" &amp;&amp; avg_popularity &lt; 40 ? "Weak Catalog" : artist_profile == "Mixed" &amp;&amp; avg_popularity &gt;= 50 ? "Growth Candidate" : "Standard Portfolio"</property>
                      </properties>
                    </outputColumn>
